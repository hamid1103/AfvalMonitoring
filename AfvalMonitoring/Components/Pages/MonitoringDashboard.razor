@page "/monitoring-dashboard"


<PageTitle>Monitoring Dashboard</PageTitle>

<h1>Monitoring Dashboard</h1>

<div class="dashboard-grid">
    <div class="dashboard-card">
        <h3>Totaal aantal meldingen</h3>
        <p class="dashboard-value">128</p>
    </div>
    <div class="dashboard-card">
        <h3>Actieve sensoren</h3>
        <p class="dashboard-value">12</p>
    </div>
    <div class="dashboard-card">
        <h3>Gemiddelde temperatuur</h3>
        <p class="dashboard-value">21.3°C</p>
    </div>
</div>

<div class="dashboard-section">
    <h2>Sensor Data Overzicht</h2>
    <div class="dashboard-chart-placeholder">
        <!-- Hier kan een grafiek component komen -->
        <em>Grafiek placeholder</em>
    </div>
</div>

@* Voeg eventueel CSS toe in een bijbehorend .razor.css bestand voor styling *@
