@page "/analytics"
@rendermode InteractiveServer
@using AfvalMonitoring.Services
@using AfvalMonitoring.Models
@inject AfvalService Service
@inject IJSRuntime JS

<h3>Afval Analyse Dashboard</h3>

<div class="mb-3" style="max-width: 420px;">
    <label for="confidenceFilter" class="form-label">
        Min confidence: @minConfidencePercentage%
    </label>
    <input id="confidenceFilter"
           type="range"
           class="form-range"
           min="0"
           max="100"
           step="1"
           @bind="minConfidencePercentage"
           @bind:event="oninput"
           @onchange="OnConfidenceChanged"
           style="direction: rtl;" />
    <div class="text-muted small">Slider loopt van 100% naar 0%. Standaard: 0% (alles >= 0%).</div>
</div>

@if (labelData == null || dagData == null)
{
    <p>Loading data...</p>
}
else
{
    <div class="mb-3">
        <strong>Totaal aantal (gefilterd): @labelData.Sum(x => x.Count)</strong>
    </div>

    <div class="row align-items-start g-4 mb-5">
        <div class="col-12 col-lg-6">
            <div style="max-width: 480px;">
                <canvas id="labelPieChart"></canvas>
            </div>
        </div>

        <div class="col-12 col-lg-6">
            <table class="table table-striped">
                <thead>
                    <tr>
                        <th>Label</th>
                        <th>Aantal</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in labelData)
                    {
                        <tr>
                            <td>@item.Label</td>
                            <td>@item.Count</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>

    <hr />
    <h4 class="mt-5 mb-4">Gegevens per dag</h4>

    <div class="row g-3">
        @foreach (var dayGroup in dagData.GroupBy(x => x.Date).OrderBy(g => g.Key))
        {
            <div class="col-12 col-md-6 col-lg-4">
                <div class="card h-100">
                    <div class="card-header bg-light">
                        <h6 class="mb-0">@dayGroup.Key.ToString("dddd, dd MMM")</h6>
                    </div>
                    <div class="card-body p-0">
                        <table class="table table-sm mb-0">
                            <tbody>
                                @foreach (var item in dayGroup.OrderBy(x => x.Label))
                                {
                                    <tr>
                                        <td>@item.Label</td>
                                        <td class="text-end"><strong>@item.Count</strong></td>
                                    </tr>
                                }
                                <tr class="table-active fw-bold">
                                    <td>Totaal</td>
                                    <td class="text-end">@dayGroup.Sum(x => x.Count)</td>
                                </tr>
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        }
    </div>
}

@code {
    private List<LabelCount>? labelData;
    private List<AfvalPerDag>? dagData;
    private int minConfidencePercentage;

    protected override async Task OnInitializedAsync()
    {
        await LoadDataAsync();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (labelData == null)
        {
            return;
        }

        await TryRenderChartAsync();
    }

    private async Task OnConfidenceChanged(ChangeEventArgs _)
    {
        await LoadDataAsync();
        await InvokeAsync(StateHasChanged);
    }

    private async Task LoadDataAsync()
    {
        labelData = await Service.GetLabelStats(minConfidencePercentage);
        dagData = await Service.GetDailyLabelStats(minConfidencePercentage);
    }

    private async Task TryRenderChartAsync()
    {
        try
        {
            await JS.InvokeVoidAsync(
                "renderLabelPieChart",
                labelData!.Select(x => x.Label).ToArray(),
                labelData.Select(x => x.Count).ToArray());
        }
        catch (JSException)
        {
            // JS nog niet beschikbaar; opnieuw proberen bij volgende render.
        }
        catch (InvalidOperationException)
        {
            // Interop nog niet beschikbaar tijdens prerender; opnieuw proberen.
        }
    }
}
