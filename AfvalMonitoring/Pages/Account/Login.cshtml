@page
@model AfvalMonitoring.Pages.Account.LoginModel
@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="nl">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Inloggen - AfvalMonitoring</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" />
</head>
<body class="bg-light">
<div class="container d-flex justify-content-center align-items-center" style="min-height:100vh">
    <div class="card shadow" style="width: 380px;">
        <div class="card-body p-4">
            <h4 class="card-title mb-4 text-center">Inloggen</h4>

            @if (!string.IsNullOrEmpty(Model.ErrorMessage))
            {
                <div class="alert alert-danger">@Model.ErrorMessage</div>
            }

            <form method="post">
                @Html.AntiForgeryToken()
                <div class="mb-3">
                    <label class="form-label">Gebruikersnaam</label>
                    <input asp-for="Input.Username" class="form-control" autocomplete="username" />
                </div>
                <div class="mb-3">
                    <label class="form-label">Wachtwoord</label>
                    <input asp-for="Input.Password" type="password" class="form-control" autocomplete="current-password" />
                </div>
                <button type="submit" class="btn btn-primary w-100">Inloggen</button>
            </form>

            <hr />
            <p class="text-center mb-0 small">
                Nog geen account? <a href="/Account/Register">Registreren</a>
            </p>
        </div>
    </div>
</div>
</body>
</html>
